{
	"semi": false,
	"singleQuote": false,
	"useTabs": true,
	"tabWidth": 2,
	"printWidth": 80,
	"trailingComma": "none",
	"endOfLine": "auto",
	"arrowParens": "always",
	"quoteProps": "as-needed",
	"bracketSpacing": true,
	"htmlWhitespaceSensitivity": "ignore",
	"importOrder": [
		"^(react/(.*)$)|^(react$)|^(react-(.*)$)",
		"^(@tanstack)/(.*)$",
		"<THIRD_PARTY_MODULES>",
		"",
		"^@/types",
		"^@/config",
		"^@/constants",
		"",
		"^@/providers",
		"",
		"^@/stores",
		"^@/schemas",
		"^@/hooks",
		"^@/lib",
		"",
		"^@/components",
		"^@/features",
		"",
		"^[./]"
	],
	"importOrderSeparation": true,
	"importOrderSortSpecifiers": true,
	"importOrderCaseInsensitive": true,
	"plugins": [
		"prettier-plugin-tailwindcss",
		"@ianvs/prettier-plugin-sort-imports"
	],
	"tailwindStylesheet": "./src/styles.css",
	"tailwindFunctions": ["clsx", "cva"]
}
