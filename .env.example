# Google Analytics 4 measurement ID
VITE_GA_ID=G-XXXXXXXXXX

# Blog data source — mdx (filesystem) | supabase (Postgres)
VITE_BLOG_DATA_SOURCE=supabase
BLOG_DATA_SOURCE=supabase

# Blog media source — see docs/supabase-migration.md → Medya sağlayıcı
# local | supabase | supabase-transform
VITE_MEDIA_PROVIDER=local

# Supabase — blog + optional media
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=
SUPABASE_URL=
SUPABASE_ANON_KEY=

# Server-only — migration scripts and draft reads in development
# SUPABASE_SERVICE_ROLE_KEY=
